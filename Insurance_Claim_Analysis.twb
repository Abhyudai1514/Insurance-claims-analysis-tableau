              <calculation class='tableau' formula='IF [INCOME] &lt; 25000 THEN &quot;Low Income&quot;&#13;&#10;&#13;&#10;ELSEIF [INCOME] &lt; 75000 THEN &quot;Medium Income&quot;&#13;&#10;&#13;&#10;ELSE &quot;High Income&quot;&#13;&#10;&#13;&#10;END' />
            </column>
