    <worksheet name='Vehicle Age &amp; Travel Risk'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#0000a2' fontname='Segoe UI' fontsize='11'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Data (Car_Insurance_Dataset_Cleaned - Copy)' name='federated.1cwp72307fy7nm1c09t5v07zbwmn' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column alias='Car Age Risk' caption='Vehicle Risk View' datatype='string' name='[Parameter 2]' param-domain-type='list' role='measure' type='nominal' value='&quot;Car Age&quot;'>
              <calculation class='tableau' formula='&quot;Car Age&quot;' />
              <aliases>
                <alias key='&quot;Car Age&quot;' value='Car Age Risk' />
                <alias key='&quot;Travtime&quot;' value='Travel Time Risk' />
              </aliases>
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1cwp72307fy7nm1c09t5v07zbwmn'>
            <column caption='Car Age' datatype='integer' name='[CAR_AGE]' role='measure' type='quantitative' />
            <column caption='Car Type' datatype='string' name='[CAR_TYPE]' role='dimension' type='nominal' />
            <column caption='Car Use' datatype='string' name='[CAR_USE]' role='dimension' type='nominal' />
            <column caption='Clm Amt' datatype='integer' default-format='c&quot;$&quot;#,##0' name='[CLM_AMT]' role='measure' type='quantitative' />
            <column caption='Avg. Claim Amount' datatype='real' default-format='c&quot;$&quot;#,##0;(&quot;$&quot;#,##0)' name='[Calculation_0122058936963078]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([CLM_AMT])' />
            </column>
            <column caption='Claim Severity Category' datatype='string' name='[Calculation_1023656399728644]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [CLM_AMT] = 0 THEN &quot;No Claim (0)&quot;&#13;&#10;ELSEIF [CLM_AMT] &lt; 5000 THEN &quot;Low(&lt;5k)&quot;&#13;&#10;ELSEIF [CLM_AMT] &lt; 15000 THEN &quot;Medium (&lt;15k)&quot;&#13;&#10;ELSE &quot;High (&gt;15k)&quot;&#13;&#10;END' />
              <aliases>
                <alias key='&quot;Medium (&lt;15k)&quot;' value='Med. (&lt;15k)' />
              </aliases>
            </column>
            <column caption='Travel Time Group' datatype='string' name='[Calculation_1040426736648192]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [TRAVTIME] &lt;= 15 THEN &quot;0-15 Min&quot;&#13;&#10;ELSEIF [TRAVTIME] &lt;= 30 THEN &quot;15-30 Min&quot;&#13;&#10;ELSEIF [TRAVTIME] &lt;= 45 THEN &quot;30-45 Min&quot;&#13;&#10;ELSEIF [TRAVTIME] &lt;= 60 THEN &quot;45-60 Min&quot;&#13;&#10;ELSE &quot;60+ Min&quot;&#13;&#10;END' />
            </column>
            <column caption='Car Age Group' datatype='string' name='[Calculation_1040426743947265]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [CAR_AGE] &lt;= 5 THEN &quot;0-5 Years&quot;&#13;&#10;&#13;&#10;ELSEIF [CAR_AGE] &lt;= 10 THEN &quot;6-10 Years&quot;&#13;&#10;&#13;&#10;ELSEIF [CAR_AGE] &lt;= 15 THEN &quot;11-15 Years&quot;&#13;&#10;&#13;&#10;ELSEIF [CAR_AGE] &lt;= 20 THEN &quot;16-20 Years&quot;&#13;&#10;&#13;&#10;ELSE &quot;21+ Years&quot;&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Dynamic Risk Group' datatype='string' name='[Calculation_1040426746118146]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;&#13;&#10;WHEN &quot;Travtime&quot; THEN [Calculation_1040426736648192]&#13;&#10;&#13;&#10;WHEN &quot;Car Age&quot; THEN [Calculation_1040426743947265]&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Education' datatype='string' name='[EDUCATION]' role='dimension' type='nominal' />
            <column caption='Gender' datatype='string' name='[GENDER]' role='dimension' type='nominal' />
            <column caption='Mstatus' datatype='string' name='[MSTATUS]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;No&quot;' value='Bachelor' />
                <alias key='&quot;Yes&quot;' value='Married' />
              </aliases>
            </column>
            <column caption='Travtime' datatype='integer' name='[TRAVTIME]' role='measure' type='quantitative' />
            <column-instance column='[CAR_TYPE]' derivation='None' name='[none:CAR_TYPE:nk]' pivot='key' type='nominal' />
            <column-instance column='[CAR_USE]' derivation='None' name='[none:CAR_USE:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1023656399728644]' derivation='None' name='[none:Calculation_1023656399728644:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1040426746118146]' derivation='None' name='[none:Calculation_1040426746118146:nk]' pivot='key' type='nominal' />
            <column-instance column='[EDUCATION]' derivation='None' name='[none:EDUCATION:nk]' pivot='key' type='nominal' />
            <column-instance column='[GENDER]' derivation='None' name='[none:GENDER:nk]' pivot='key' type='nominal' />
