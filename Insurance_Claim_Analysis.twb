      <aliases enabled='yes' />
      <column caption='Birth' datatype='date' name='[BIRTH]' role='dimension' type='ordinal' />
      <column caption='Bluebook' datatype='integer' name='[BLUEBOOK]' role='measure' type='quantitative' />
      <column aggregation='None' datatype='integer' name='[Bluebook (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='3' formula='[BLUEBOOK]' peg='0' size='1618' />
      </column>
      <column caption='Car Age' datatype='integer' name='[CAR_AGE]' role='measure' type='quantitative' />
      <column caption='Car Type' datatype='string' name='[CAR_TYPE]' role='dimension' type='nominal' />
      <column caption='Car Use' datatype='string' name='[CAR_USE]' role='dimension' type='nominal' />
      <column caption='Clm Amt' datatype='integer' default-format='c&quot;$&quot;#,##0' name='[CLM_AMT]' role='measure' type='quantitative' />
      <column caption='Clm Freq' datatype='integer' name='[CLM_FREQ]' role='measure' type='quantitative' />
      <column caption='Average Income' datatype='real' default-format='c&quot;$&quot;#,##0,K' name='[Calculation_0122058936098821]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([INCOME])' />
      </column>
      <column caption='Avg. Claim Amount' datatype='real' default-format='c&quot;$&quot;#,##0;(&quot;$&quot;#,##0)' name='[Calculation_0122058936963078]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([CLM_AMT])' />
      </column>
      <column caption='Parent Claim %' datatype='real' default-format='p0.0%' name='[Calculation_0122058938175495]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [HOMEKIDS] &gt; 0&#13;&#10;THEN 1&#13;&#10;END&#13;&#10;)&#13;&#10;/COUNT([ID])' />
      </column>
      <column caption='Home kids Segment' datatype='string' name='[Calculation_0122058941739016]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [HOMEKIDS] &gt;= 3 THEN &quot;HomeKids 3+&quot;&#13;&#10;ELSEIF [HOMEKIDS] = 2 THEN &quot;HomeKids 2&quot;&#13;&#10;ELSEIF [HOMEKIDS] = 1 THEN &quot;HomeKids 1&quot;&#13;&#10;ELSE &quot;No Kids&quot;&#13;&#10;END' />
      </column>
      <column caption='Home Kids Group' datatype='string' name='[Calculation_0122058950328329]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [HOMEKIDS] &gt;= 4 THEN &quot;4+ Kids&quot;&#13;&#10;&#13;&#10;ELSEIF [HOMEKIDS] = 3 THEN &quot;3 Kids&quot;&#13;&#10;&#13;&#10;ELSEIF [HOMEKIDS] = 2 THEN &quot;2 Kids&quot;&#13;&#10;&#13;&#10;ELSEIF [HOMEKIDS] = 1 THEN &quot;1 Kid&quot;&#13;&#10;&#13;&#10;ELSE &quot;0 Kids&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Parent %' datatype='real' default-format='p0.0%' name='[Calculation_0122058978263052]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [PARENT1] = &quot;Yes&quot; THEN 1&#13;&#10;ELSE 0&#13;&#10;END) / COUNT([ID])' />
      </column>
      <column caption='Selected Financial Driver' datatype='real' name='[Calculation_0302929445593089]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 3]&#13;&#10;&#13;&#10;WHEN &quot;Income&quot; THEN [INCOME]&#13;&#10;&#13;&#10;WHEN &quot;Home Val&quot; THEN [HOME_VAL]&#13;&#10;&#13;&#10;WHEN &quot;Bluebook&quot; THEN [BLUEBOOK]&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Old Claim Band' datatype='string' name='[Calculation_0302929452187650]' role='dimension' type='nominal'>
