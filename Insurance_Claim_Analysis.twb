              <calculation class='tableau' formula='IF [HOME_VAL] &lt; 100000 THEN &quot;Low Home&quot;&#13;&#10;&#13;&#10;ELSEIF [HOME_VAL] &lt; 300000 THEN &quot;Medium Home&quot;&#13;&#10;&#13;&#10;ELSE &quot;High Home&quot;&#13;&#10;&#13;&#10;END' />
